      "id": "996b051b-d4c0-4d7d-be04-a0e8852a6714",
      "name": "Filter",
      "notesInFlow": true,
      "notes": "Filter USD and EUR"
    },
    {
      "parameters": {
        "jsCode": "const result = {};\n\nfor (const item of items) {\n  const currency = item.json.currency_short; // USD, EUR, GBP\n  const currencyName = item.json.currency;   // US Dollar\n  const rate = Number(item.json.rate);\n  const date = item.json.exchange_date;\n\n  if (!result[currency]) {\n    result[currency] = {\n      currency: currencyName,\n      currency_short: currency,\n\n      min_rate: rate,\n      min_date: date,\n\n      max_rate: rate,\n      max_date: date,\n\n      current_rate: rate,\n      current_date: date,\n    };\n  }\n\n  // Min rate\n  if (rate < result[currency].min_rate) {\n    result[currency].min_rate = rate;\n    result[currency].min_date = date;\n  }\n\n  // Max rate\n  if (rate > result[currency].max_rate) {\n    result[currency].max_rate = rate;\n    result[currency].max_date = date;\n  }\n\n  // Current rate\n  if (\n    new Date(date.split('.').reverse().join('-')) >\n    new Date(result[currency].current_date.split('.').reverse().join('-'))\n  ) {\n    result[currency].current_rate = rate;\n    result[currency].current_date = date;\n  }\n}\n\nreturn [\n  {\n    json: {\n      currencies: Object.values(result)\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1568,
        -624
      ],
      "id": "f59b4076-8554-4e77-b89b-4cdb240faf06",
      "name": "Code in JavaScript",
      "notesInFlow": true,
      "notes": "Calc.Min / Max / Current Rates"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a financial analyst .\nAnalyze the exchange rate statistics provided below and generate short summary in email.\nPeriod of exchange rate analysis (Start - End period ).\nFor each currency:\n- State the current exchange rate.\n- Minimum exchange rate and the date when it occurred.\n- Maximum exchange rate and the date when it occurred.\n\nData:\n{{ JSON.stringify($json.currencies) }}\n\nReturn only the email body.\nDo not add greetings, signatures, placeholders, or closing remarks.\nDo not use *, **, #, or bullet markdown syntax.\nReturn plain text only.",
        "options": {}
      },
